import os
import subprocess
import json
import time

CONFIG_FILE = "memory/instant/system_state.json"

SERVICES = [
{
"name": "Symfony API",
"path": "backend/symfony-api",
"start": "symfony server:start"
},
{
"name": "Laravel Core",
"path": "backend/laravel-core",
"start": "php artisan serve"
},
{
"name": "React Dashboard",
"path": "frontend/react-dashboard",
"start": "npm start"
}
]

def log(message):
print(f"[MIA-BOOT] {message}")

def verifier_dependances():
log("Vérification des dépendances...")

dependances = [
"composer",
"php",
"python",
"node",
"npm"
]

for dep in dependances:
try:
subprocess.run([dep, "--version"], check=True,
stdout=subprocess.DEVNULL)
log(f"{dep} OK")
except:
log(f"{dep} MANQUANT")

def installer_dependances():
projets = [
("backend/symfony-api", "composer install"),
("backend/laravel-core", "composer install"),
("frontend/react-dashboard", "npm install")
]

for path, cmd in projets:
log(f"Installation dépendances : {path}")
subprocess.run(cmd, cwd=path, shell=True)

def lancer_services():
for service in SERVICES:
log(f"Démarrage : {service['name']}")

subprocess.Popen(
service["start"],
cwd=service["path"],
shell=True
)

def charger_identite():
with open("memory/instant/identity_core.json",
"r",
encoding="utf-8") as f:
return json.load(f)

def afficher_message_bienvenue(identity):
print("\n==============================")
print(f"Bienvenue {identity['IA_IDENTITY']['nom']}")
print(identity['IA_MISSION']['raison_d_etre'])
print("==============================\n")

if __name__ == "__main__":

verifier_dependances()

installer_dependances()

identite = charger_identite()

afficher_message_bienvenue(identite)

lancer_services()

log("Tous les services sont actifs.")

